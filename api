<!DOCTYPE html>
<html>
<head>
    <title>Solicitud de Seguro</title>
</head>
<body>

<h2>Formulario de Seguro</h2>

<form>

    <label>Nombre completo:</label><br>
    <input type="text" name="nombre"><br><br>

    <label>Cédula:</label><br>
    <input type="text" name="cedula"><br><br>

    <label>Teléfono:</label><br>
    <input type="text" name="telefono"><br><br>

    <label>Correo:</label><br>
    <input type="email" name="correo"><br><br>

    <label>Tipo de seguro:</label><br>
    <select name="tipo_seguro">
        <option>Vida</option>
        <option>Auto</option>
        <option>Hogar</option>
        <option>Salud</option>
    </select>

    <br><br>

    <button type="submit">
        Solicitar Seguro
    </button>

</form>

</body>
</html>
